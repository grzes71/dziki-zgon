   166 				;==============================================================
   167 				; copy_gameover_text — Kopiuje tekst GAME OVER (32 B) z ROM do RAM ($5E10)
   168 				;==============================================================
   169 25C1			.proc copy_gameover_text
   170 25C1 A9 AB		    lda #<GO_TEXT_Data
   171 25C3 85 82		    sta SRC_PTR
   172 25C5 A9 27		    lda #>GO_TEXT_Data
   173 25C7 85 83		    sta SRC_PTR+1
   174 25C9 A9 10		    lda #<FOOTER_ADDR
   175 25CB 85 84		    sta DST_PTR
   176 25CD A9 5E		    lda #>FOOTER_ADDR
