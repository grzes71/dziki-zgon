   113 				    ; Czekaj na puszczenie przycisku FIRE z poprzedniego ekranu
   114 2484 AD 10 D0		    lda TRIG0
   115 2487 F0 11		    beq @move            ; wciąż trzyma — nie reaguj i idź do ruchu
   116 2489 A9 01		    lda #1
   117 248B 8D FC 23		    sta game_fire_released
   118 248E 4C 9A 24		    jmp @move
   119
   120 2491			@check_press
   121 				    ; --- TEST: FIRE → następny etap ---
   122 2491 AD 10 D0		    lda TRIG0
   123 2494 D0 04		    bne @move
   124 2496 20 D9 25		    jsr advance_stage
   125 2499 60			    rts
   126
   127 249A			@move
   128 				    ; --- Odczyt joysticka (PORT A, $D300) ---
   129 249A AD 00 D3		    lda PORTA
   130 249D 49 FF		    eor #$FF            ; neguj (0=neutral, 1=aktywny kierunek)
   131
   132 				    ; GÓRA
   133 249F 29 01		    and #$01
   134 24A1 F0 03		    beq @chk_down
   135 24A3 CE 00 D0		    dec HPOSP0
   136
   137 24A6			@chk_down
   138 24A6 AD 00 D3		    lda PORTA
   139 24A9 49 FF		    eor #$FF
   140 24AB 29 02		    and #$02
   141 24AD F0 03		    beq @chk_left
   142 24AF EE 00 D0		    inc HPOSP0
   143
   144 24B2			@chk_left
   145 24B2 AD 00 D3		    lda PORTA
   146 24B5 49 FF		    eor #$FF
   147 24B7 29 04		    and #$04
   148 24B9 F0 03		    beq @chk_right
   149 24BB CE 00 D0		    dec HPOSP0
   150
   151 24BE			@chk_right
   152 24BE AD 00 D3		    lda PORTA
   153 24C1 49 FF		    eor #$FF
   154 24C3 29 08		    and #$08
   155 24C5 F0 03		    beq @exit
   156 24C7 EE 00 D0		    inc HPOSP0
   157
   158 24CA			@exit
   159 24CA 60			    rts
   160 				.endp
