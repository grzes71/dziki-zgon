     1 				; ===================================================================
     2 				; music/audio.asm — MADS configuration and integration of RMT player
     3 				; Configured to load at free RAM sector $8800
     4 				; ===================================================================
     5
     6 = E45C			SETVBV = $E45C
     7 = E462			XITVBV = $E462
     8
     9 7AE0			    org $8800
    10
    11 				; --- Initialize RMT and set up Deferred VBLANK ---
    12 8800			audio_init
    13 8800-8845> A2 00		    ldx #<MODUL
    14 8802 A0 92		    ldy #>MODUL
    15 8804 A9 00		    lda #0                  ; Subsong number
    16 8806 20 00 8C		    jsr RASTERMUSICTRACKER  ; Init player
    17
    18 8809 A9 07		    lda #7                  ; Deferred VBLANK slot
    19 880B A2 88		    ldx #>vblank_player     ; High byte of handler
    20 880D A0 13		    ldy #<vblank_player     ; Low byte of handler
    21 880F 20 5C E4		    jsr SETVBV              ; Install VBI via OS
    22 8812 60			    rts
    23
    24 				; --- Deferred VBI Music player handler ---
    25 8813			vblank_player
    26 8813 20 03 8C		    jsr RASTERMUSICTRACKER+3 ; Play one frame
    27 8816 4C 62 E4		    jmp XITVBV              ; Exit Deferred VBI handler
    28
    29 				; --- Stop audio and silence Pokey ---
    30 8819			audio_stop
    31 8819 A9 07		    lda #7                  ; Deferred VBLANK slot
    32 881B A2 88		    ldx #>dummy_vbi         ; High byte of dummy handler
    33 881D A0 43		    ldy #<dummy_vbi         ; Low byte of dummy handler
    34 881F 20 5C E4		    jsr SETVBV              ; Unhook vblank_player
    35
    36 8822 20 09 8C		    jsr RASTERMUSICTRACKER+9 ; Silence tracker player
    37
    38 				    ; Clear Pokey audio registers
    39 8825 A9 00		    lda #0
    40 8827 8D 00 D2		    sta $D200
    41 882A 8D 01 D2		    sta $D201
    42 882D 8D 02 D2		    sta $D202
    43 8830 8D 03 D2		    sta $D203
    44 8833 8D 04 D2		    sta $D204
    45 8836 8D 05 D2		    sta $D205
    46 8839 8D 06 D2		    sta $D206
    47 883C 8D 07 D2		    sta $D207
    48 883F 8D 08 D2		    sta $D208
    49 8842 60			    rts
    50
    51 8843			dummy_vbi
    52 8843 4C 62 E4		    jmp XITVBV
    53
    54 				; --- Player and variables mapping ---
    55 				; Define player location (must be page aligned)
    56 = 8C00			PLAYER = $8C00
