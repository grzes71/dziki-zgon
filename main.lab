    30
    31 				; ===================================================================
    32 				; Tablica kolejności etapów (development: zmień DEV_START_STAGE w hardware.asm)
    33 				; ===================================================================
    34 25D5			stage_order
    35 25D5 00			    dta STATE_TITLE     ; 0
    36 25D6 01			    dta STATE_STORY     ; 1
    37 25D7 02			    dta STATE_GAME      ; 2
    38 25D8 03			    dta STATE_OVER      ; 3
    39 = 0004			STAGE_COUNT = * - stage_order
    40
    41 				; ===================================================================
    42 				; advance_stage — Przechodzi do następnego etapu wg tablicy stage_order
    43 				; Szuka bieżącego GAME_STATE w tablicy, bierze następny element
    44 				; (lub pierwszy, jeśli to był ostatni — wrap-around)
    45 				; Niszczy: A, X
    46 				; ===================================================================
    47 25D9			.proc advance_stage
    48 25D9 A2 00		    ldx #0
    49 25DB			@find
    50 25DB BD D5 25		    lda stage_order,x
    51 25DE C5 81		    cmp GAME_STATE
    52 25E0 F0 07		    beq @found
    53 25E2 E8			    inx
    54 25E3 E0 04		    cpx #STAGE_COUNT
    55 25E5 D0 F4		    bne @find
    56 				    ; Nie znaleziono — fallback: idź do pierwszego etapu
    57 25E7 A2 03		    ldx #STAGE_COUNT-1    ; ostatni indeks — poniżej zrobi +1 → wrap na 0
    58
    59 25E9			@found
    60 25E9 E8			    inx
    61 25EA E0 04		    cpx #STAGE_COUNT
    62 25EC D0 02		    bne @store
    63 25EE A2 00		    ldx #0               ; wrap-around: po ostatnim wróć do pierwszego
    64
    65 25F0			@store
    66 25F0 BD D5 25		    lda stage_order,x
    67 25F3 85 81		    sta GAME_STATE
    68 25F5 60			    rts
    69 				.endp
    70
    71 				; ===================================================================
    72 				; system_init — Wspólna inicjalizacja sprzętu dla wszystkich etapów
    73 				; Wywoływana przed każdym scene_init (i w start)
    74 				; Niszczy: A
    75 				; ===================================================================
    76 25F6			.proc system_init
    77 25F6 D8			    cld                     ; clear decimal mode (po resecie D może być nieznany!)
    78 25F7 78			    sei                     ; blokada IRQ
    79 25F8 A9 00		    lda #0
    80 25FA 8D 0E D2		    sta IRQEN               ; wyłącz przerwania POKEY
    81 25FD 8D 00 D4		    sta DMACTL              ; wyłącz DMA na czas konfiguracji
    82 2600 8D 0E D4		    sta NMIEN               ; wyłącz NMI (DLI + VBI) — kluczowe przy DEV_START_STAGE>0
    83 2603 8D 1D D0		    sta GRACTL              ; wyłącz PMG DMA
    84
    85 				    ; --- Wyczyszczenie rejestrów GTIA (pozycje, rozmiary i grafika PMG) ---
    86 2606 A2 11		    ldx #$11
    87 2608			@clr_gtia
    88 2608 9D 00 D0		    sta $D000,x
    89 260B CA			    dex
    90 260C 10 FA		    bpl @clr_gtia
    91
    92 260E A9 FF		    lda #$FF                ; %11111111: bit 0=1 (OS ROM ON), bit 1=1 (BASIC OFF)
    93 2610 8D 01 D3		    sta PORTB               ; odsłoń RAM spod BASIC ROM ($A000–$BFFF)
    94 2613 60			    rts
    95 				.endp
    96
    97 				; ===================================================================
    98 				; 3. Punkt startowy — inicjalizacja systemu
    99 				; ===================================================================
   100 2614			start
   101 2614 20 F6 25		    jsr system_init
   102
   103 				    ; Ustaw stan początkowy z tablicy stage_order (wg DEV_START_STAGE)
   104 2617 A2 00		    ldx #DEV_START_STAGE
   105 2619 E0 04		    cpx #STAGE_COUNT
   106 261B 90 02		    bcc @ok
   107 261D A2 00		    ldx #0                  ; fallback: title
   108 261F			@ok
   109 261F BD D5 25		    lda stage_order,x
   110 2622 85 81		    sta GAME_STATE
   111
   112 				; ===================================================================
   113 				; 4. Pętla główna — maszyna stanów
   114 				; ===================================================================
   115 2624			main_loop
   116 2624 A5 81		    lda GAME_STATE
   117 2626 C9 00		    cmp #STATE_TITLE
   118 2628 D0 15		    bne @chk_story
   119 262A 20 F6 25		    jsr system_init
   120 262D 20 8B 20		    jsr title_init
   121 2630 20 CF 21		@tl jsr title_run
   122 2633 A5 81		    lda GAME_STATE
   123 2635 C9 00		    cmp #STATE_TITLE
   124 2637 F0 F7		    beq @tl
   125 2639 20 19 88		    jsr audio_stop          ; Stop the music on state exit
   126 263C 4C 24 26		    jmp main_loop
   127
   128 263F			@chk_story
