Source: gameover_colors.asm
     1 				; Kolory dla: gameover
     2 				; Automatycznie dopasowane do palety Atari (PAL)
     3 				;
     4 				; Zapis BEZPOŚREDNIO do rejestrów GTIA (VBI wyłączony).
     5 				;
     6 				;   COLBK  ($D01A)
     7 				;   COLPF0 ($D016)
     8 				;   COLPF1 ($D017)
     9 				;   COLPF2 ($D018)
    10 				;
    11 				;   indeks 0 → COLBK  $D01A = $00  (RGB #000001 → hue=0 (szary), lum=0)
    12 				;   indeks 1 → COLPF0 $D016 = $0A  (RGB #BDBCBD → hue=0 (szary), lum=10)
    13 				;   indeks 2 → COLPF1 $D017 = $02  (RGB #464646 → hue=0 (szary), lum=2)
    14 				;   indeks 3 → COLPF2 $D018 = $05  (RGB #7E7E7D → hue=0 (szary), lum=5)
    15
    16 				; --- Stałe kolorów (MADS .equ) — do użycia w DLI ---
    17 = 0000			GAMEOVER_COLBK	= $00
    18 = 000A			GAMEOVER_COLPF0	= $0A
    19 = 0002			GAMEOVER_COLPF1	= $02
    20 = 0005			GAMEOVER_COLPF2	= $05
    21
    22 				; --- Inicjalizacja kolorów (GTIA hardware registers) ---
    23 24CB A9 00			lda #$00
    24 24CD 8D 1A D0			sta $D01A	; COLBK (tło)
    25 24D0 A9 0A			lda #$0A
    26 24D2 8D 16 D0			sta $D016	; COLPF0 (playfield 0)
    27 24D5 A9 02			lda #$02
    28 24D7 8D 17 D0			sta $D017	; COLPF1 (playfield 1)
    29 24DA A9 05			lda #$05
    30 24DC 8D 18 D0			sta $D018	; COLPF2 (playfield 2)
     8
     9 				;---- Zmienne lokalne sceny ----
    10 24DF			gameover_fire_released
    11 24DF 00			    dta $00
    12
    13 				;==============================================================
    14 				; DLI_Gameover — Obrazek + płynne migotanie tekstu (ANTIC mode 3)
    15 				; (1) pierwsza linia DL ($F0) — przywraca kolory obrazka
    16 				; (2) blank przed tekstem ($F0) — ustawia COLPF2 na kolor z tabeli
    17 				; Kolor zmienia się co klatkę (10 klatek = pełny cykl)
    18 				;==============================================================
    19 = 000A			RAINBOW_LEN = 10
    20
    21 24E0			.proc DLI_Gameover
    22 24E0 48			    pha
    23 24E1 8A			    txa
    24 24E2 48			    pha
    25
    26 24E3 AD 37 25		    lda go_dli_toggle
    27 24E6 D0 17		    bne @blink
    28
    29 24E8			@restore
    30 				    ; --- Obrazek: przywróć COLPF0–2 z palety ---
    31 24E8 A9 0A		    lda #GAMEOVER_COLPF0
    32 24EA 8D 16 D0		    sta COLPF0
    33 24ED A9 02		    lda #GAMEOVER_COLPF1
    34 24EF 8D 17 D0		    sta COLPF1
    35 24F2 A9 05		    lda #GAMEOVER_COLPF2
    36 24F4 8D 18 D0		    sta COLPF2
    37 24F7 A9 01		    lda #1
    38 24F9 8D 37 25		    sta go_dli_toggle
    39 24FC 4C 33 25		    jmp @done
    40
    41 24FF			@blink
    42 				    ; --- Migotanie: ustaw COLPF2 na bieżący kolor z tabeli ---
    43 24FF A9 00		    lda #0
    44 2501 8D 16 D0		    sta COLPF0            ; nieużywane (standardowe znaki)
    45 2504 8D 18 D0		    sta COLPF2
    46 2507 AE 38 25		    ldx go_pulse_idx
    47 250A BD 3A 25		    lda GoRainbow,x
    48 250D 8D 17 D0		    sta COLPF1            ; kolor tekstu dla tej klatki
    49
    50 				    ; Spowolnienie ×2: inkrementuj go_pulse_idx co 2 klatki
    51 2510 EE 39 25		    inc go_subframe
    52 2513 AD 39 25		    lda go_subframe
    53 2516 C9 02		    cmp #2
    54 2518 D0 14		    bne @reset_done
    55 251A A9 00		    lda #0
    56 251C 8D 39 25		    sta go_subframe
    57 251F EE 38 25		    inc go_pulse_idx
    58 2522 AD 38 25		    lda go_pulse_idx
    59 2525 C9 0A		    cmp #RAINBOW_LEN
    60 2527 D0 05		    bne @reset_done
    61 2529 A9 00		    lda #0
    62 252B 8D 38 25		    sta go_pulse_idx      ; wrap do 0 po pełnym cyklu
    63 252E			@reset_done
    64 252E A9 00		    lda #0
    65 2530 8D 37 25		    sta go_dli_toggle
    66
    67 2533			@done
    68 2533 68			    pla
    69 2534 AA			    tax
    70 2535 68			    pla
    71 2536 40			    rti
    72 				.endp
    73
    74 2537			go_dli_toggle
    75 2537 00			    dta $00
    76 2538			go_pulse_idx
    77 2538 00			    dta $00
    78 2539			go_subframe
    79 2539 00			    dta $00
    80
    81 				; Kolory migotania dla COLPF2 — 10 kolorów, zmiana co klatkę
    82 253A			GoRainbow
    83 253A 30			    dta $30     ; 0: ciemny pomarańcz
    84 253B 32			    dta $32     ; 1
    85 253C 34			    dta $34     ; 2
    86 253D 36			    dta $36     ; 3: czerwony
    87 253E 38			    dta $38     ; 4
    88 253F 3A			    dta $3A     ; 5
    89 2540 3C			    dta $3C     ; 6
    90 2541 3C			    dta $3C     ; 7
    91 2542 3E			    dta $3E     ; 8
    92 2543 3E			    dta $3E     ; 9: jasny pomarańcz
    93
    94 2544			.proc gameover_init
    95 2544 A9 00		    lda #0
    96 2546 8D 00 D4		    sta DMACTL
    97 2549 8D 0E D4		    sta NMIEN
    98 254C 8D 1D D0		    sta GRACTL              ; wyłącz PMG DMA (GTIA)
    99 254F 8D 1B D0		    sta PRIOR               ; reset priorytetów
   100 2552 8D DF 24		    sta gameover_fire_released ; zresetuj stan przycisku FIRE
   101 2555 8D 37 25		    sta go_dli_toggle       ; DLI toggle: 0 = obrazek
   102 2558 8D 38 25		    sta go_pulse_idx        ; indeks migotania: 0
   103 255B 8D 39 25		    sta go_subframe         ; spowolnienie ×2: 0
   104
   105 255E 20 03 20		    jsr pmg_clear_all
   106 2561 20 C1 25		    jsr copy_gameover_text
   107
   108 				    ; --- Display List (ANTIC D + tekst) ---
   109 2564 A9 8B		    lda #<DLIST_GAMEOVER
   110 2566 8D 02 D4		    sta DLISTL
   111 2569 A9 3F		    lda #>DLIST_GAMEOVER
   112 256B 8D 03 D4		    sta DLISTH
   113
   114 				    ; --- Charset (własny font $6000) ---
   115 256E A9 60		    lda #$60
   116 2570 8D 09 D4		    sta CHBASE
   117
   118 				    ; --- Kolory z wygenerowanego pliku ---
   119 2573 A9 00		    lda #GAMEOVER_COLBK
   120 2575 8D 1A D0		    sta COLBK
   121 2578 A9 0A		    lda #GAMEOVER_COLPF0
   122 257A 8D 16 D0		    sta COLPF0
   123 257D A9 02		    lda #GAMEOVER_COLPF1
   124 257F 8D 17 D0		    sta COLPF1
   125 2582 A9 05		    lda #GAMEOVER_COLPF2
   126 2584 8D 18 D0		    sta COLPF2
   127 2587 A9 00		    lda #$00
   128 2589 8D 19 D0		    sta COLPF3            ; 5th player — nieużywany
   129
   130 				    ; --- DLI: wektor + enable ---
   131 258C A9 E0		    lda #<DLI_Gameover
   132 258E 8D 00 02		    sta VDSLST
   133 2591 A9 24		    lda #>DLI_Gameover
   134 2593 8D 01 02		    sta VDSLST+1
   135 2596 A9 80		    lda #$80              ; DLI on, VBI off
   136 2598 8D 0E D4		    sta NMIEN
   137
   138 				    ; --- DMA ON (narrow playfield — 128 pikseli, bez PMG) ---
   139 259B A9 21		    lda #$21
   140 259D 8D 00 D4		    sta DMACTL
   141
   142 25A0 60			    rts
   143 				.endp
   144
   145 25A1			.proc gameover_run
   146 25A1 AD DF 24		    lda gameover_fire_released
   147 25A4 D0 0D		    bne @check_press
   148
   149 				    ; Czekaj na puszczenie przycisku FIRE z poprzedniego ekranu
   150 25A6 AD 10 D0		    lda TRIG0
   151 25A9 F0 15		    beq @exit            ; wciąż trzyma — nie reaguj
   152 25AB A9 01		    lda #1
   153 25AD 8D DF 24		    sta gameover_fire_released
   154 25B0 4C C0 25		    jmp @exit
   155
   156 25B3			@check_press
   157 25B3 AD 10 D0		    lda TRIG0
