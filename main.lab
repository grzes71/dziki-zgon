Source: pmg.asm
     1 				;----------------------------------------
     2 				; lib/pmg.asm — Procedury pomocnicze PMG
     3 				;----------------------------------------
     4
     5 				;--------------------------------------------------------------
     6 				; pmg_clear_all — Zeruje całą pamięć PMG (wszystkie 5 buforów)
     7 				; Zakres: 0..239 (120 linii × 2 dla double-line, ale
     8 				;          single-line w tym projekcie używa pełnych 128 B)
     9 				; Niszczy: A, X
    10 				;--------------------------------------------------------------
    11 2003			.proc pmg_clear_all
    12 2003 A9 00		    lda #0
    13 2005 A2 EF		    ldx #239
    14 2007			@lp
    15 2007 9D 00 A4		    sta PLAYER0,x
    16 200A 9D 00 A5		    sta PLAYER1,x
    17 200D 9D 00 A6		    sta PLAYER2,x
    18 2010 9D 00 A7		    sta PLAYER3,x
    19 2013 9D 00 A3		    sta MISSILES,x
    20 2016 CA			    dex
    21 2017 10 EE		    bpl @lp
    22 2019 60			    rts
    23 				.endp
    24
    25 				;--------------------------------------------------------------
    26 				; pmg_clear_range — Zeruje zakres linii PMG
    27 				; Wejście:  X = indeks ostatniej linii do wyzerowania (odliczanie do 0)
    28 				; Niszczy:  A, X
    29 				;--------------------------------------------------------------
    30 201A			.proc pmg_clear_range
    31 201A A9 00		    lda #0
    32 201C			@lp
    33 201C 9D 00 A4		    sta PLAYER0,x
    34 201F 9D 00 A5		    sta PLAYER1,x
    35 2022 9D 00 A6		    sta PLAYER2,x
    36 2025 9D 00 A7		    sta PLAYER3,x
    37 2028 9D 00 A3		    sta MISSILES,x
    38 202B CA			    dex
    39 202C 10 EE		    bpl @lp
    40 202E 60			    rts
    41 				.endp
