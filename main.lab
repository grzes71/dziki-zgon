     1 				;----------------------------------------
     2 				; hardware.asm — Rejestry sprzętowe i stałe projektowe
     3 				; Współdzielone przez wszystkie moduły gry
     4 				; Atari XL/XE, ANTIC E (160x192, 4 kolory) + PMG
     5 				;----------------------------------------
     6
     7 				; ---- GTIA (CTIA/GTIA — generowanie obrazu, kolory, PMG) ----
     8 = D000			HPOSP0  = $D000     ; pozycja X gracza P0 (0..255 color clocks)
     9 = D001			HPOSP1  = $D001     ; pozycja X gracza P1
    10 = D002			HPOSP2  = $D002     ; pozycja X gracza P2
    11 = D003			HPOSP3  = $D003     ; pozycja X gracza P3
    12 = D004			HPOSM0  = $D004     ; pozycja X pocisku M0
    13 = D005			HPOSM1  = $D005     ; pozycja X pocisku M1
    14 = D006			HPOSM2  = $D006     ; pozycja X pocisku M2
    15 = D007			HPOSM3  = $D007     ; pozycja X pocisku M3
    16 = D008			SIZEP0  = $D008     ; szerokość gracza P0 (00=normal, 01=x2, 11=x4)
    17 = D009			SIZEP1  = $D009     ; szerokość gracza P1
    18 = D00A			SIZEP2  = $D00A     ; szerokość gracza P2
    19 = D00B			SIZEP3  = $D00B     ; szerokość gracza P3
    20 = D00C			SIZEM   = $D00C     ; szerokość wszystkich pocisków (te same bity co SIZEP)
    21 = D012			PCOLR0  = $D012     ; kolor gracza P0 + pocisku M0
    22 = D013			PCOLR1  = $D013     ; kolor gracza P1 + pocisku M1
    23 = D014			PCOLR2  = $D014     ; kolor gracza P2 + pocisku M2
    24 = D015			PCOLR3  = $D015     ; kolor gracza P3 + pocisku M3
    25 = D016			COLPF0  = $D016     ; kolor playfield 0 (indeks 1 w palecie ANTIC E)
    26 = D017			COLPF1  = $D017     ; kolor playfield 1 (indeks 2)
    27 = D018			COLPF2  = $D018     ; kolor playfield 2 (indeks 3)
    28 = D019			COLPF3  = $D019     ; kolor playfield 3 / 5. gracza (missiles) gdy PRIOR bit 4=1
    29 = D01A			COLBK   = $D01A     ; kolor tła (COLBAK) — wspólny dla playfield i PMG
    30 = D01B			PRIOR   = $D01B     ; priorytety: bit 4=5th player, bity 1-0=tryb priorytetu
    31 = D01D			GRACTL  = $D01D     ; włączenie DMA PMG: bit 0=P/M, bit 1=missiles
    32
    33 				; ---- PIA (Port Interface Adapter — PORTB, banki pamięci) ----
    34 = D301			PORTB   = $D301     ; bit 0=OS ROM, bit 1=BASIC, bity 7-2=banki rozszerzonej pamięci
    35
    36 				; ---- ANTIC (kontroler DMA, Display List) ----
    37 = D400			DMACTL  = $D400     ; włączenie DMA: bit 5=playfield, bity 1-0=rozdzielczość PMG
    38 = D402			DLISTL  = $D402     ; młodszy bajt adresu Display List
    39 = D403			DLISTH  = $D403     ; starszy bajt adresu Display List
    40 = D407			PMBASE  = $D407     ; adres bazowy pamięci PMG (musi być wyrównany do 1K)
    41 = D409			CHBASE  = $D409     ; adres bazowy fontu (znaków) — górny bajt, dolny zawsze $00
    42 = D40A			WSYNC   = $D40A     ; Wait for Sync — zapis zatrzymuje CPU do początku następnej linii
    43 = D40F			NMIST   = $D40F     ; rejestr statusu NMI: bit 7=DLI, bit 6=VBI (odczyt kasuje)
    44 = D40E			NMIEN   = $D40E     ; włączenie NMI: bit 7=DLI, bit 6=VBI
    45
    46 				; ---- POKEY (dźwięk, klawiatura, timery) ----
    47 = D20E			IRQEN   = $D20E     ; włączenie przerwań IRQ z POKEY
    48
    49 				; ---- OS shadows (cienie rejestrów w RAM) ----
    50 				; UWAGA: shadow registers wymagają VBI — projekt ma VBI wyłączone!
    51 				; Wszystkie zapisy idą bezpośrednio do hardware (GTIA/ANTIC $D0xx-$D4xx)
    52 = 0200			VDSLST  = $0200     ; wektor DLI (2 bajty: lo, hi) — używany przez OS NMI handler
    53
    54 				; ---- Joystick ----
    55 = 0284			STRIG0  = $0284     ; cień przycisku FIRE (NIEAKTUALNY bez VBI — użyj TRIG0!)
    56 = D010			TRIG0   = $D010     ; GTIA — przycisk FIRE joysticka 0 (bit 0=0 gdy wciśnięty)
    57 = D300			PORTA   = $D300     ; PORT A PIA — joystick 0 (bity 0–3: góra/dół/lewo/prawo, 0=aktywny)
    58
    59 				; ---- Mapa pamięci projektu ----
    60 = 4000			SCREEN      = $4000         ; bufor ekranu (ANTIC E, 160x192)
    61 = 3E80			DLIST_ADDR  = $3E80         ; adres bazowy Display List
    62 = A000			PMBASE_ADDR = $A000         ; pamięć PMG (1K-aligned, pod ROM BASIC)
    63 = 5E10			FOOTER_ADDR = $5E10         ; stopka tekstowa (ANTIC mode 2, 40 znaków)
    64
    65 				; ---- Offsety PMG (single-line resolution) ----
    66 = A300			MISSILES    = PMBASE_ADDR+$300   ; 256 B — wszystkie 4 missile w 1 bajcie/linia
    67 = A400			PLAYER0     = PMBASE_ADDR+$400   ; 256 B
    68 = A500			PLAYER1     = PMBASE_ADDR+$500   ; 256 B
    69 = A600			PLAYER2     = PMBASE_ADDR+$600   ; 256 B
    70 = A700			PLAYER3     = PMBASE_ADDR+$700   ; 256 B
    71
    72 				; ---- Wymiary sprite'ów — tytuł ----
    73 = 0025			SPRITE_ROWS = 37
    74 = 0026			TOP_MARGIN  = 38
    75
    76 				; ---- Wymiary sprite'ów — księżyc (4 graczy, 32px) ----
    77 = 0018			MOON_ROWS   = 24
    78 = 0064			MOON_TOP    = 100            ; pozycja Y księżyca (linia PMG) — musi być > TOP_MARGIN+SPRITE_ROWS
    79 = 0030			MOON_X      = $30            ; pozycja X lewego skraju księżyca
    80
    81 				; ---- Gwiazdy — na missile'ach M0–M3 (tylko PMG data placement, NIE DLI timing) ----
    82 = 0050			STAR0_X     = $50
    83 = 0048			STAR1_X     = $48
    84 = 0060			STAR2_X     = $60
    85 = 0074			STAR3_X     = $74
    86
    87 = 005A			STAR0_Y     = 90            ; linia PMG — tuż nad księżycem
    88 = 006E			STAR1_Y     = 110            ; w obszarze księżyca
    89 = 005F			STAR2_Y     = 95
    90 = 0064			STAR3_Y     = 100
    91
    92 				; ---- Timing DLI ----
    93 = 0008			KOREKTA     = 8              ; dostrojone doświadczalnie
    94 = 0018			DL_BLANKS   = 24
    95 = 0006			DLI_DELAY   = TOP_MARGIN - DL_BLANKS - KOREKTA
    96
    97 				; ---- Pozycje PMG tytułu (color clocks, side by side, x1 = 8px apart) ----
    98 = 0030			TITLE_X     = $30            ; lewy skraj całego napisu
    99 = 0030			HPOS_P0     = TITLE_X
   100 = 0038			HPOS_P1     = TITLE_X+$08
   101 = 0040			HPOS_P2     = TITLE_X+$10
   102 = 0048			HPOS_P3     = TITLE_X+$18
   103 = 0050			HPOS_M      = TITLE_X+$20    ; 5th player — M3 (lewy skraj)
   104
   105 				; ---- PMG DMA ----
   106 = 003E			DMA_PMG_ON  = $3E            ; %00111110 = playfield ON + PMG single-line
   107 = 0003			GRACTL_PM   = $03            ; włącz P/M + missiles
   108 = 0011			PRIOR_5TH   = $11            ; 5th player mode + players over playfield
   109
   110 				; ---- Stany gry ----
   111 = 0000			STATE_TITLE = 0
   112 = 0001			STATE_STORY = 1
   113 = 0002			STATE_GAME  = 2
   114 = 0003			STATE_OVER  = 3
   115
   116 				; ---- Development — indeks etapu startowego (0=title, 1=story, 2=game, 3=gameover) ----
   117 = 0000			DEV_START_STAGE = 0         ; zmień, by wystartować od innego etapu podczas developmentu
