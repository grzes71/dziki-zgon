   159 25B8 A9 00		    lda #0
   160 25BA 8D 0E D4		    sta NMIEN              ; wyłącz DLI przed zmianą stanu
   161 25BD 20 D9 25		    jsr advance_stage      ; powrót do pierwszego etapu z tablicy
   162 25C0			@exit
   163 25C0 60			    rts
