Source: rle.asm
     1 				; =============================================================================
     2 				; Depacker RLE (run-length encoding) dla 6502
     3 				;
     4 				; Format RLE:
     5 				;   Bajt flagi (cmd):
     6 				;     bit 7 = 1 -> powtórzenie: bity 6..0 = liczba powtórzeń - 1 (1..128)
     7 				;                  Wyjątek: cmd = $80 -> EOF (koniec danych)
     8 				;     bit 7 = 0 -> literały:    bity 6..0 = długość - 1 (1..128)
     9 				;
    10 				; Wejście:
    11 				;   SRC_PTR (word) – adres skompresowanych danych (Strona Zerowa)
    12 				;   DST_PTR (word) – adres bufora docelowego (Strona Zerowa)
    13 				;
    14 				; Niszczy: A, X, Y
    15 				; =============================================================================
    16
    17 202F			.proc RLE_Depack
    18 202F A0 00		        ldy #0
    19
    20 2031			loop
    21 				        ; --- Odczytaj bajt flagi ---
    22 2031 B1 82		        lda (SRC_PTR),Y
    23 2033 AA			        tax                 ; zachowaj bajt flagi w X
    24 2034 E6 82		        inc SRC_PTR
    25 2036 D0 02		        bne skip_inc_src
    26 2038 E6 83		        inc SRC_PTR+1
    27 203A			skip_inc_src
    28 203A 8A			        txa                 ; przywróć bajt flagi do A (odnawia flagi N i Z!)
    29 203B 30 19		        bmi do_repeat       ; bit 7 = 1 -> powtórzenie lub EOF
    30
    31 				        ; --- Literały (bit 7 = 0) ---
    32 203D AA			        tax                 ; X = liczba literałów - 1
    33 203E E8			        inx                 ; X = liczba literałów (1..128)
    34 203F A0 00		        ldy #0
    35 2041			@lit_copy
    36 2041 B1 82		        lda (SRC_PTR),Y
    37 2043 91 84		        sta (DST_PTR),Y
    38 2045 E6 82		        inc SRC_PTR
    39 2047 D0 02		        bne @lit_skip_src
    40 2049 E6 83		        inc SRC_PTR+1
    41 204B			@lit_skip_src
    42 204B E6 84		        inc DST_PTR
    43 204D D0 02		        bne @lit_skip_dst
    44 204F E6 85		        inc DST_PTR+1
    45 2051			@lit_skip_dst
    46 2051 CA			        dex
    47 2052 D0 ED		        bne @lit_copy
    48 2054 F0 DB		        beq loop            ; zawsze powrót do głównej pętli
    49
    50 				        ; --- Powtórzenie (bit 7 = 1) ---
    51 2056			do_repeat
    52 2056 29 7F		        and #$7F            ; bity 6..0 = liczba powtórzeń - 1
    53 2058 F0 1B		        beq exit_rle        ; jeśli bity 6..0 == 0 (czyli pierwotnie cmd = $80), to EOF!
    54 205A AA			        tax
    55 205B E8			        inx                 ; X = liczba powtórzeń (1..128)
    56 205C A0 00		        ldy #0
    57 205E B1 82		        lda (SRC_PTR),Y      ; wczytaj bajt do powtórzenia
    58 2060 E6 82		        inc SRC_PTR
    59 2062 D0 02		        bne @rep_skip_src
    60 2064 E6 83		        inc SRC_PTR+1
    61 2066			@rep_skip_src
    62 2066 A0 00		        ldy #0
    63 2068			@rep_store
    64 2068 91 84		        sta (DST_PTR),Y
    65 206A E6 84		        inc DST_PTR
    66 206C D0 02		        bne @rep_skip_dst
    67 206E E6 85		        inc DST_PTR+1
    68 2070			@rep_skip_dst
    69 2070 CA			        dex
    70 2071 D0 F5		        bne @rep_store
    71 2073 F0 BC		        beq loop            ; powrót do głównej pętli
    72
    73 2075			exit_rle
    74 2075 60			        rts
    75 				.endp
