Source: title_colors.asm
     1 				; Kolory dla: title
     2 				; Automatycznie dopasowane do palety Atari (PAL)
     3 				;
     4 				; Zapis BEZPOŚREDNIO do rejestrów GTIA (VBI wyłączony).
     5 				;
     6 				;   COLBK  ($D01A)
     7 				;   COLPF0 ($D016)
     8 				;   COLPF1 ($D017)
     9 				;   COLPF2 ($D018)
    10 				;
    11 				;   indeks 0 → COLBK  $D01A = $00  (RGB #000000 → hue=0 (szary), lum=0)
    12 				;   indeks 1 → COLPF0 $D016 = $02  (RGB #4A4A4A → hue=0 (szary), lum=2)
    13 				;   indeks 2 → COLPF1 $D017 = $24  (RGB #AD5A08 → hue=2 (pomarańczowy), lum=4)
    14 				;   indeks 3 → COLPF2 $D018 = $28  (RGB #CD9367 → hue=2 (pomarańczowy), lum=8)
    15
    16 				; --- Stałe kolorów (MADS .equ) — do użycia w DLI ---
    17 = 0000			TITLE_COLBK	= $00
    18 = 0002			TITLE_COLPF0	= $02
    19 = 0024			TITLE_COLPF1	= $24
    20 = 0028			TITLE_COLPF2	= $28
    21
    22 				; --- Inicjalizacja kolorów (GTIA hardware registers) ---
    23 2076 A9 00			lda #$00
    24 2078 8D 1A D0			sta $D01A	; COLBK (tło)
    25 207B A9 02			lda #$02
    26 207D 8D 16 D0			sta $D016	; COLPF0 (playfield 0)
    27 2080 A9 24			lda #$24
    28 2082 8D 17 D0			sta $D017	; COLPF1 (playfield 1)
    29 2085 A9 28			lda #$28
    30 2087 8D 18 D0			sta $D018	; COLPF2 (playfield 2)
     8
     9 				;---- Zmienne lokalne sceny ----
    10 208A			title_fire_released
    11 208A 00			    dta $00
    12
    13 				;==============================================================
    14 				; title_init — Konfiguracja ekranu tytułowego
    15 				; Wywoływane RAZ przy wejściu w ten stan
    16 				;==============================================================
    17 208B			.proc title_init
    18 				    ; --- Wyłącz DMA na czas konfiguracji ---
    19 208B A9 00		    lda #0
    20 208D 8D 00 D4		    sta DMACTL
    21 2090 8D 8A 20		    sta title_fire_released
    22
    23 				    ; --- Wyczyść całą pamięć PMG ---
    24 2093 20 03 20		    jsr pmg_clear_all
    25
    26 				    ; --- Transpozycja sprite'ów tytułu → PMG ---
    27 				    ; Format źródłowy: [P0,P1,P2,P3,M5th] × 37 wierszy
    28 				    ; Format PMG:       per-player, ciągiem 128 B, offset TOP_MARGIN
    29 				    
    30 				    ; Rozpakuj SpriteData (logo) do bufora tymczasowego $3000
    31 2096 A9 FA		    lda #<SpriteData
    32 2098 85 82		    sta SRC_PTR
    33 209A A9 28		    lda #>SpriteData
    34 209C 85 83		    sta SRC_PTR+1
    35 209E A9 00		    lda #$00
    36 20A0 85 84		    sta DST_PTR
    37 20A2 A9 30		    lda #$30
    38 20A4 85 85		    sta DST_PTR+1
    39 20A6 20 2F 20		    jsr RLE_Depack
    40
    41 20A9 A2 24		    ldx #SPRITE_ROWS-1
    42
    43 20AB			@row_loop
    44 				    ; Oblicz offset źródłowy: X * 5
    45 20AB 8A			    txa
    46 20AC 85 80		    sta SRC_TMP
    47 20AE 0A			    asl @               ; *2
    48 20AF 0A			    asl @               ; *4
    49 20B0 18			    clc
    50 20B1 65 80		    adc SRC_TMP          ; +1 → *5
    51 20B3 A8			    tay                  ; Y = offset w źródle
    52
    53 20B4 B9 00 30		    lda $3000,y
    54 20B7 9D 26 A4		    sta PLAYER0+TOP_MARGIN,x
    55 20BA C8			    iny
    56 20BB B9 00 30		    lda $3000,y
    57 20BE 9D 26 A5		    sta PLAYER1+TOP_MARGIN,x
    58 20C1 C8			    iny
    59 20C2 B9 00 30		    lda $3000,y
    60 20C5 9D 26 A6		    sta PLAYER2+TOP_MARGIN,x
    61 20C8 C8			    iny
    62 20C9 B9 00 30		    lda $3000,y
    63 20CC 9D 26 A7		    sta PLAYER3+TOP_MARGIN,x
    64 20CF C8			    iny
    65 20D0 B9 00 30		    lda $3000,y
    66 20D3 9D 26 A3		    sta MISSILES+TOP_MARGIN,x
    67
    68 20D6 CA			    dex
    69 20D7 10 D2		    bpl @row_loop
    70
    71 				    ; --- Transpozycja księżyca → PMG (P0–P3, 24 wiersze) ---
    72 20D9 A2 17		    ldx #MOON_ROWS-1
    73 20DB			@mclear
    74 20DB A9 00		    lda #0
    75 20DD 9D 64 A3		    sta MISSILES+MOON_TOP,x
    76 20E0 CA			    dex
    77 20E1 10 F8		    bpl @mclear
    78
    79 				    ; Rozpakuj MoonData (księżyc) do bufora tymczasowego $3000
    80 20E3 A9 8F		    lda #<MoonData
    81 20E5 85 82		    sta SRC_PTR
    82 20E7 A9 29		    lda #>MoonData
    83 20E9 85 83		    sta SRC_PTR+1
    84 20EB A9 00		    lda #$00
    85 20ED 85 84		    sta DST_PTR
    86 20EF A9 30		    lda #$30
    87 20F1 85 85		    sta DST_PTR+1
    88 20F3 20 2F 20		    jsr RLE_Depack
    89
    90 20F6 A2 17		    ldx #MOON_ROWS-1
    91 20F8			@moon_loop
    92 20F8 8A			    txa
    93 20F9 0A			    asl @
    94 20FA 0A			    asl @               ; X * 4
    95 20FB A8			    tay
    96 20FC B9 00 30		    lda $3000,y
    97 20FF 9D 64 A4		    sta PLAYER0+MOON_TOP,x
    98 2102 C8			    iny
    99 2103 B9 00 30		    lda $3000,y
   100 2106 9D 64 A5		    sta PLAYER1+MOON_TOP,x
   101 2109 C8			    iny
   102 210A B9 00 30		    lda $3000,y
   103 210D 9D 64 A6		    sta PLAYER2+MOON_TOP,x
   104 2110 C8			    iny
   105 2111 B9 00 30		    lda $3000,y
